# Game-Servum — Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an

# ── Netzwerk ──
# PORT=3001
# HOST=0.0.0.0

# ── Pfade ──
# STEAMCMD_PATH=C:\GameServum\steamcmd
# SERVERS_PATH=C:\GameServum\servers
# DATA_PATH=C:\GameServum\data

# ── CORS ──
# Komma-separierte Liste erlaubter Origins (oder * für alle)
# CORS_ORIGINS=https://dashboard.example.com,http://localhost:5173

# ── Authentifizierung ──
# true  = API-Key + Passwort erforderlich (Standard für sicheren Remote-Zugriff)
# false = kein Auth (nur für lokale Entwicklung)
# AUTH_ENABLED=true

# JWT-Secret — wird automatisch generiert wenn nicht gesetzt
# JWT_SECRET=
