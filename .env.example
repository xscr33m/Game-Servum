# Game-Servum — Configuration
# Copy this file to .env and adjust the values

# ── Network ──
# PORT=3001
# HOST=0.0.0.0

# ── Paths ──
# STEAMCMD_PATH=C:\GameServum\steamcmd
# SERVERS_PATH=C:\GameServum\servers
# DATA_PATH=C:\GameServum\data

# ── CORS ──
# Comma-separated list of allowed origins (or * for all)
# CORS_ORIGINS=https://dashboard.example.com,http://localhost:5173

# ── Authentication ──
# true  = API key + password required (default for secure remote access)
# false = no auth (for local development only)
# AUTH_ENABLED=true

# JWT secret — auto-generated if not set
# JWT_SECRET=

# ── TLS / HTTPS ──
# TLS is enabled by default. On first start, a self-signed certificate
# is automatically generated (data/agent.crt + data/agent.key).
# Set TLS_ENABLED=false to use HTTP instead of HTTPS (e.g. for local development).
# TLS_ENABLED=true
